# =============================================================================
# Dockerfile.server -- Server image for SandboxFusion
# =============================================================================
# Extends the base sandbox image (which provides all language toolchains) with
# runtime dependencies, the Python application code, and user/permission setup.
#
# Optimization notes:
# - APT lists cleaned after each install layer
# - .NET NuGet cache cleared after warm-up
# - Lean .lake build cache trimmed
# - .git directory removed from copied repo
# - pip/conda caches cleaned after installs
# =============================================================================

FROM ineil77/sandbox-fusion-base:24042026

# ---------------------------------------------------------------------------
# Docker CLI (required for full mode to spawn sibling execution containers)
# ---------------------------------------------------------------------------
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Go runtime: copy source and build (caches Go module downloads)
# ---------------------------------------------------------------------------
COPY ./runtime/go ./runtime/go
RUN cd ./runtime/go \
    && go build \
    && go clean -cache

# ---------------------------------------------------------------------------
# Node.js runtime: install npm dependencies and Puppeteer system libraries
# ---------------------------------------------------------------------------
COPY ./runtime/node /root/sandbox/runtime/node
RUN cd /root/sandbox/runtime/node && npm ci \
    && npm cache clean --force \
    && apt-get update -y && apt-get install -y --no-install-recommends \
        fontconfig locales libasound2t64 libatk1.0-0t64 libc6 libcairo2 \
        libcups2t64 libdbus-1-3 libexpat1 libfontconfig1 libgcc-s1 \
        libgdk-pixbuf-xlib-2.0-0 libglib2.0-0t64 libgtk-3-0t64 libnspr4 \
        libpango-1.0-0 libpangocairo-1.0-0 libstdc++6 libx11-6 libx11-xcb1 \
        libxcb1 libxcomposite1 libxcursor1 libxdamage1 libxext6 libxfixes3 \
        libxi6 libxrandr2 libxrender1 libxss1 libxtst6 ca-certificates \
        fonts-liberation libnss3 lsb-release xdg-utils libgbm-dev \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# .NET cache: warm NuGet packages then clean caches
# ---------------------------------------------------------------------------
RUN dotnet new console -o /tmp/dotnet && dotnet run --project /tmp/dotnet \
    && rm -rf /tmp/dotnet \
    && dotnet nuget locals all --clear 2>/dev/null || true \
    && rm -rf /tmp/NuGet* /tmp/.dotnet

# ---------------------------------------------------------------------------
# Lean runtime: copy lakefile and build, then trim build cache
# ---------------------------------------------------------------------------
COPY ./runtime/lean /root/sandbox/runtime/lean
RUN cd /root/sandbox/runtime/lean && lake build \
    && rm -rf /root/.elan/toolchains/leanprover-lean4-v4.29.0/lib/lean4/doc 2>/dev/null || true

# ---------------------------------------------------------------------------
# Python runtime: copy and install via install-python-runtime.sh
# ---------------------------------------------------------------------------
COPY ./runtime/python ./runtime/python
RUN cd ./runtime/python && bash install-python-runtime.sh \
    && rm -rf /root/.cache/pip

# ---------------------------------------------------------------------------
# Application code: copy full repo and install Poetry deps
# ---------------------------------------------------------------------------
COPY ./ /root/sandbox
WORKDIR /root/sandbox
RUN rm -rf /root/sandbox/.git \
    && rm -rf /root/sandbox/documentation \
    && poetry config virtualenvs.create false \
    && touch /root/miniconda3/pyvenv.cfg \
    && poetry install \
    && rm -rf /root/.cache/pip /root/.cache/pypoetry \
    && find /root/sandbox -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true

# ---------------------------------------------------------------------------
# Non-root user and permissions setup
# ---------------------------------------------------------------------------
RUN useradd -m app && echo 'app:app' | chpasswd \
    && chmod og+rx /root \
    && mkdir -p /mnt \
    && chmod og+rwx /mnt

# ---------------------------------------------------------------------------
# Entrypoint: launch the sandbox server via run.sh
# ---------------------------------------------------------------------------
CMD bash /root/sandbox/scripts/run.sh
